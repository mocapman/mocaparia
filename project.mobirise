    "pao-de-queijo.html": {
      "settings": {
        "title": "Pão de Queijo",
        "order": "19",
        "meta_descr": "A recipe worth keeping, because not all meaningful data comes in sentence form."
      },
      "components": [
        {
          "alias": false,
          "_styles": {
            "z-index": "1000",
            "width": "100%",
            "position": "relative",
            ".dropdown-item:before": {
              "font-family": "Moririse2 !important",
              "content": "\"\\e966\"",
              "display": "inline-block",
              "width": "0",
              "position": "absolute",
              "left": "1rem",
              "top": "0.5rem",
