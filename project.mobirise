            "& when (@reverseContent)": {
              ".row": {
                "flex-direction": "row-reverse"
              }
            },
            ".mbr-text": {
              "color": "#000000",
              "text-align": "justify",
              "margin-bottom": "2em",
              "@media (max-width: 992px)": {
                "margin-bottom": "1.5rem"
              },
              "@media (max-width: 767px)": {
                "margin-bottom": "1rem"
              }
