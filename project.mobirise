    "give-it-to-me.html": {
      "settings": {
        "title": "Give it to me!",
        "order": "9",
        "meta_descr": "A thought piece about gifts, gratitude, and the strange difference between wanting things and being known."
      },
      "components": [
        {
          "alias": false,
          "_styles": {
            "z-index": "1000",
            "width": "100%",
            "position": "relative",
            ".dropdown-item:before": {
