    "ireland-2026.html": {
      "settings": {
        "title": "Ireland 2026",
        "order": "18",
        "meta_descr": "Proposed itinerary for our trip to Ireland  in May 2026."
      },
      "components": [
        {
          "alias": false,
          "_styles": {
            "z-index": "1000",
            "width": "100%",
            "position": "relative",
            ".dropdown-item:before": {
              "font-family": "Moririse2 !important",
              "content": "\"\\e966\"",
              "display": "inline-block",
              "width": "0",
              "position": "absolute",
              "left": "1rem",
