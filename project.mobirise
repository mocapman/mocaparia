    "slim-shady.html": {
      "settings": {
        "title": "Slim Shady",
        "order": "6",
        "meta_descr": "A reflection on mortality, matter, and the uncomfortable fact that we are all just temporary arrangements pretending to be permanent."
      },
      "components": [
        {
          "alias": false,
