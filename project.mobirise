          "_name": "article02",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"start article2\" group=\"Article\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n\t<mbr-parameters>\n\t\t<header>Size</header>\n\t\t<input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n\t\t<input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n\t\t<input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"4\" condition=\"fullScreen == false\">\n\t\t<input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"0\" condition=\"fullScreen == false\">\n\t\t<input type=\"range\" inline name=\"imageWidth\" title=\"Image\" min=\"4\" max=\"8\" step=\"1\" value=\"6\">\n\t\t<input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\" checked>\n\t\t<header>Show/Hide</header>\n\t\t<input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n\t\t<input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n\t\t<input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n\t\t<header>Background</header>\n\t\t<fieldset type=\"background\" name=\"bg\" parallax>\n\t\t\t<input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/joan-1-2000x3556.jpg\" selected>\n\t\t\t<input type=\"color\" title=\"Color\" value=\"#ffffff\">\n\t\t\t<input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n\t\t</fieldset>\n\t\t<header condition=\"bg.type === 'video'\">Fallback Image</header>\n\t\t<input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n\t\t<input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n\t\t<input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n\t\t<input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.6\" condition=\"overlay && bg.type !== 'color'\">\n\t</mbr-parameters>\n\n\t<div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n\t<div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n\t<div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n\t\t<div class=\"row justify-content-center\">\n\t\t\t<div class=\"col-12 col-md-12 col-lg-{{imageWidth}} image-wrapper\">\n\t\t\t\t<img class=\"w-100\" src=\"@PROJECT_PATH@/assets/images/silvercreekmill-500x375.jpg\" alt=\"Mobirise Website Builder\">\n\t\t\t</div>\n\t\t\t<div class=\"col-12 col-md-12 col-lg\">\n\t\t\t\t<div class=\"text-wrapper align-left\">\n\t\t\t\t\t<h1 class=\"mbr-section-title mbr-fonts-style mb-4\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"caveat-large\" mbr-if=\"showTitle\"><b>we came from dust</b></h1>\n\t\t\t\t\t<p class=\"mbr-text align-left mbr-fonts-style mb-4\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\">not every life is well kept by the world\n<br>\n<br>the world prefers its records simple\n<br>a name on stone\n<br>a line in a book\n<br>a building somebody can point to and say\n<br>that was theirs\n<br>\n<br>but some lives find purpose in the dust\n<br>they are spent in motion\n<br>in service\n<br>not standing back from life\n<br>but taking hold of it\n<br>and making room for more of it\n<br>\n<br>for music\n<br>for stories\n<br>for history\n<br>for laughter\n<br>for one more chair at the table\n<br>for One more child to gather in\n<br>for one more broken thing\n<br>to be made useful and beautiful again\n<br>\n<br>such a life is easy for the world to underestimate\n<br>it leaves no spectacle behind\n<br>no proper accounting\n<br>no guarantee that memory will do its duty\n<br>\n<br>snowflakes melt\n<br>memory follows\n<br>but a life like that\n<br>melts snow\n<br>like a Ray of light\n<br>making room\n<br>for more life\n<br>\n<br>some lives leave more life behind\n<br>\n<br>they are not made smaller\n<br>because they were not properly praised\n<br>they are not emptied of meaning\n<br>because the world forgets the name\n<br>\n<br>meaning was never the plaque\n<br>never the credit\n<br>\n<br>Meaning is to spend a life on what matters\n<br>without needing witness\n<br>to leave warmth where one stands\n<br>to answer need with energy\n<br>to make beauty practical\n<br>to be for others\n<br>a kind of Ray\n<br>\n<br>that kind of life does not disappear\n<br>just because memory fails\n<br>\n<br>it remains in the people it shaped\n<br>in the good it set in motion\n<br>in the reflection it leaves for the rest of us\n<br>\n<br>and in remembering such a life\n<br>something in us wants to be more than memory\n<br>something in us wants meaning too\n<br>\n<br>what are we making room for\n<br>what are we giving\n<br>what are we building\n<br>what for this brief moment\n<br>will be more alive\n<br>while we are here\n<br>because We are here.</p>\n\t\t\t\t\t<div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn align-left mt-3\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n\t\t\t\t\t\t<a class=\"btn btn-success-outline\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">Get started</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n</section>",
