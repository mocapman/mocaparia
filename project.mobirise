    "calibrating.html": {
      "settings": {
        "title": "Calibrating",
        "order": "4",
        "meta_descr": "These are thoughts still looking for their skeleton. Words in motion. Ideas circling the volume, trying to see if they belong to something real or just needed a place to stretch."
      },
