        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "background-color": "@bgColor",
            "& when not (@reverseContent)": {
              ".main-row": {
                "flex-direction": "row"
              }
            },
            "& when (@reverseContent)": {
              ".main-row": {
                "flex-direction": "row-reverse"
              }
            },
            ".mbr-section-title": {
              "text-align": "center",
              "color": "#d70081"
            },
            ".mbr-text, .mbr-section-btn": {
              "text-align": "center"
            },
            ".item-wrapper": {
              "@media (max-width: 991px)": {
                "margin-bottom": "3rem"
              },
              "@media (min-width: 992px)": {
                "padding": "4rem"
              }
            },
            ".dragArea": {
