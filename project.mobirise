    "markerless-thoughts.html": {
      "settings": {
        "title": "Markerless Thoughts",
        "order": "12",
        "meta_descr": "A piece about tribalism, conspiracies, and the human habit of locking onto certainty without enough evidence."
      },
      "components": [
        {
          "alias": false,
          "_styles": {
            "z-index": "1000",
            "width": "100%",
            "position": "relative",
            ".dropdown-item:before": {
              "font-family": "Moririse2 !important",
              "content": "\"\\e966\"",
